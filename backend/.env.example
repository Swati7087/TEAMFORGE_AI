PORT=5000
MONGO_URI=mongodb+srv://...
JWT_SECRET=
JWT_EXPIRES_IN=7d
SESSION_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GEMINI_API_KEY=
# Optional. Defaults to "gemini-flash-latest" (Google-maintained alias).
# If you see "limit: 0" / quota errors, use a lite model that has free tier on your account:
#   gemini-flash-lite-latest   (recommended fallback)
#   gemini-3.1-flash-lite
GEMINI_MODEL=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# 32+ char secret used to encrypt stored GitHub PATs (AES-256-CBC).
GITHUB_TOKEN_ENCRYPTION_KEY=
# Optional — for scripts/test-phase5a.ps1 live GitHub checks only (never commit real values).
GITHUB_TEST_TOKEN=
GITHUB_TEST_REPO_URL=
FRONTEND_URL=http://localhost:5173,http://localhost:5174
